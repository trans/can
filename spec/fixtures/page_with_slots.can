<.def tag="layout" param:heading="String"><header><h1>{heading}</h1><.slot name="nav"/></header><main><.slot/></main><footer><.slot name="footer"/></footer></.def>

<layout heading="Hello, {user}!"><:nav><a href="/">home</a></:nav><p>welcome, {user}</p><:footer><small>© {year}</small></:footer></layout>
